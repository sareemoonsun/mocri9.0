    {
        "id": "0141fbe882fe6869",
        "type": "function",
        "z": "b005dd89083e4bbd",
        "name": "Generate Data (CSV Format)",
        "func": "var d = new Date();\nvar date = d.getFullYear();\ndate += \"/\" + (d.getMonth() + 1); // เพิ่ม +1 เพราะเดือนเริ่มที่ 0\ndate += \"/\" + d.getDate();\ndate += \" \" + d.getHours();\ndate += \":\" + d.getMinutes();\ndate += \":\" + d.getSeconds();\n\nvar tempp = msg.payload.temperature;// 0.0 - 50.0\nvar humid = msg.payload.humidity;   // 50.0 - 100.0\n\n// สร้าง String สำหรับบันทึกลง CSV\nvar data = date + \",\" + tempp.toFixed(2) + \",\" + humid.toFixed(2);\n\nmsg.payload = data;\nreturn msg;",
